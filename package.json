{
  "name": "promptloom",
  "version": "1.1.0",
  "description": "Weave production-grade LLM prompts with cache boundaries, tool injection, and token budgeting. Reverse-engineered from Claude Code's 7-layer prompt architecture.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "promptloom": "bin/cli.ts"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run bin/cli.ts",
    "build": "tsup",
    "test": "bun test",
    "check": "bunx tsc --noEmit",
    "release": "bun run build && release-it"
  },
  "devDependencies": {
    "@types/bun": "^1.3",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeanutSplash/promptloom.git"
  },
  "keywords": [
    "llm",
    "prompt",
    "anthropic",
    "claude",
    "openai",
    "cache",
    "token"
  ]
}
